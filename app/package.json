{
  "name": "app",
  "version": "0.0.0",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile=bunvel-app --sourcemap=inline --minify-whitespace --minify-syntax",
    "start": "./bunvel-app",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "elysia": "^1.4.29",
    "elysia-http-exception": "^0.1.5",
    "elysia-rate-limit": "^4.6.2",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "pino-pretty": "^13.1.3"
  },
  "module": "src/index.js"
}
